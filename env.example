# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# CORS Configuration
# Comma-separated; supports wildcards (e.g., https://*.vercel.app)
# For production, include your Vercel domain and any other frontend domains
CORS_ORIGIN=http://localhost:3000,https://pixelsqueeze-3y9rhgtwl-nikhil-sharmas-projects-8afcbff3.vercel.app,https://*.vercel.app

# Sentry (optional)
SENTRY_DSN=

# Rate Limiting
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=900000

# Database Configuration (for production)
MONGODB_URI=mongodb://localhost:27017/pixelsqueeze
MONGODB_URI_PROD=mongodb+srv://username:password@cluster.mongodb.net/pixelsqueeze

# AWS S3 Configuration (for production)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_STARTER=price_starter_plan_id
STRIPE_PRICE_PRO=price_pro_plan_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_plan_id

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_starter_plan_id
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_pro_plan_id
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=price_enterprise_plan_id

# Image Processing
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp
TEMP_UPLOAD_DIR=./uploads/temp

# Subscription Plans (in cents)
FREE_TIER_LIMIT=100
STARTER_TIER_LIMIT=5000
PRO_TIER_LIMIT=20000
ENTERPRISE_TIER_LIMIT=100000

# File Retention (in hours)
FILE_RETENTION_HOURS=24

# Logging
LOG_LEVEL=info

# App URLs (used in emails)
PUBLIC_APP_URL=http://localhost:3000

# SMTP (for password reset emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM="PixelSqueeze <no-reply@pixelsqueeze.app>" 

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID= 