{
  "name": "pixelsqueeze",
  "version": "1.0.0",
  "description": "Cloud-based image optimization platform with API service",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "server:dev:simple": "nodemon server/dev-server.js",
    "client:dev": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "reset:password": "node scripts/reset-password.js",
    "test": "jest",
    "docker:build": "docker build -t pixelsqueeze .",
    "docker:run": "docker run -p 3000:3000 -p 5000:5000 pixelsqueeze"
  },
  "keywords": [
    "image-optimization",
    "saas",
    "api",
    "compression"
  ],
  "author": "PixelSqueeze Team",
  "license": "MIT",
  "dependencies": {
    "@stripe/stripe-js": "^7.8.0",
    "archiver": "^6.0.1",
    "aws-sdk": "^2.1490.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "imagemin": "^8.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "sharp": "^0.33.0",
    "stripe": "^14.25.0",
    "uuid": "^9.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
